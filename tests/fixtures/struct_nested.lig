-- Nested types: struct inside union, union inside struct

-- Point struct
def Point : prop := struct
  x : int
  y : int

-- Shape union with struct payload
def Shape : prop := union
  | Circle of (center : Point) (radius : int)
  | Rectangle of (tl : Point) (br : Point)
  | Empty

-- Construct and check
#check Circle (Point.mk 0 0) 5 : Shape
#check Rectangle (Point.mk 1 1) (Point.mk 4 5) : Shape
#check Empty : Shape

-- Option union
def Option : prop := union
  | None
  | Some of (val : int)

-- Config struct with union field
def Config : prop := struct
  name : str
  opt : Option

#check Config.mk "server" (Some 8080) : Config
#check Config.mk "default" None : Config

-- Show struct with union field
def cfg : Config := Config.mk "test" (Some 42)
#eval Config.name cfg
